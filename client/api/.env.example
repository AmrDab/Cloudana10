# Orchestrator API Server Configuration
# Contract addresses are read from shared/addresses.{network}.json (NOT from this file)
# See: ORCHESTRATOR_CONTRACT_ADDRESS_DESIGN.md

# Server
PORT=7002

# Orchestrator Event-Driven Mode
ORCHESTRATOR_EVENT_DRIVEN_ENABLED=true
ORCHESTRATOR_EVENT_DEBOUNCE_MS=2000

# Orchestrator Polling Mode (optional backup)
ORCHESTRATOR_POLL_ENABLED=false
ORCHESTRATOR_POLL_INTERVAL_MS=60000

# Private Key (REQUIRED for orchestrator to sign transactions)
# This is the orchestrator's wallet private key for writing to blockchain
ORCHESTRATOR_PRIVATE_KEY=your_private_key_here

# ==========================================
# RPC Transport Configuration
# ==========================================

# Transport mode: 'http' | 'websocket' | 'hybrid'
# - http: HTTP polling (simple, reliable, 8-16s latency)
# - websocket: WebSocket subscription (fast, 2-5s latency, requires WSS support)
# - hybrid: WebSocket primary with HTTP fallback (recommended for production)
ORCHESTRATOR_RPC_TRANSPORT=http

# RPC URLs
ORCHESTRATOR_CHAIN_RPC_URL=https://sepolia.base.org
# ORCHESTRATOR_CHAIN_WSS_URL=wss://sepolia.base.org

# WebSocket configuration (used for 'websocket' and 'hybrid' modes)
ORCHESTRATOR_WEBSOCKET_RETRY_COUNT=3
ORCHESTRATOR_WEBSOCKET_RETRY_DELAY=3000

# ==========================================
# Example Configurations for Different Providers
# ==========================================

# --- Alchemy (recommended for production) ---
# ORCHESTRATOR_RPC_TRANSPORT=hybrid
# ORCHESTRATOR_CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# ORCHESTRATOR_CHAIN_WSS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# --- QuickNode ---
# ORCHESTRATOR_RPC_TRANSPORT=hybrid
# ORCHESTRATOR_CHAIN_RPC_URL=https://YOUR_ENDPOINT.quiknode.pro/YOUR_API_KEY/
# ORCHESTRATOR_CHAIN_WSS_URL=wss://YOUR_ENDPOINT.quiknode.pro/YOUR_API_KEY/

# --- Base Public RPC (free, HTTP only) ---
# ORCHESTRATOR_RPC_TRANSPORT=http
# ORCHESTRATOR_CHAIN_RPC_URL=https://sepolia.base.org

# --- Infura ---
# ORCHESTRATOR_RPC_TRANSPORT=hybrid
# ORCHESTRATOR_CHAIN_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_PROJECT_ID
# ORCHESTRATOR_CHAIN_WSS_URL=wss://base-sepolia.infura.io/ws/v3/YOUR_PROJECT_ID

# ==========================================
# Workload Status Polling Configuration
# ==========================================

# Enable workload status polling (monitors provider node execution status)
WORKLOAD_STATUS_POLLING_ENABLED=true
WORKLOAD_STATUS_POLL_INTERVAL_MS=15000  # Poll every 15 seconds
WORKLOAD_STATUS_CACHE_TTL_MS=60000      # Cache TTL 60 seconds

# ==========================================
# Other Optional Configuration
# ==========================================

# IPFS gateway for fetching workload/provider metadata (default: https://gateway.pinata.cloud)
# If fetches time out, try: https://cloudflare-ipfs.com or https://ipfs.io
# IPFS_GATEWAY=https://gateway.pinata.cloud

# Optional: Override network (defaults to baseSepolia)
# CHAIN_NETWORK=baseSepolia
# CHAIN_ID=84532

# Optional: Override shared directory path
# SHARED_PATH=/path/to/shared
