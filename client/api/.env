# Orchestrator API Server Configuration
# Contract addresses are read from shared/addresses.{network}.json (NOT from this file)
# See: ORCHESTRATOR_CONTRACT_ADDRESS_DESIGN.md

# Server
PORT=7002

# Orchestrator Event-Driven Mode
ORCHESTRATOR_EVENT_DRIVEN_ENABLED=true
ORCHESTRATOR_EVENT_DEBOUNCE_MS=2000

# Private Key (REQUIRED for orchestrator to sign transactions)
# This is the orchestrator's wallet private key for writing to blockchain
ORCHESTRATOR_PRIVATE_KEY=3b2e9fc2e5caf8d505fccbd93cc7783a126ac60a4a343df098366515482283c3

# RPC Transport Configuration
# Transport mode: 'http' | 'websocket' | 'hybrid'
# - http: HTTP polling (simple, reliable, 8-16s latency)
# - websocket: WebSocket subscription (fast, 2-5s latency, requires WSS support)
# - hybrid: WebSocket primary with HTTP fallback (recommended for production)
ORCHESTRATOR_RPC_TRANSPORT=websocket

# RPC URLs
ORCHESTRATOR_CHAIN_RPC_URL=https://base-sepolia.drpc.org
ORCHESTRATOR_CHAIN_WSS_URL=wss://base-sepolia.g.alchemy.com/v2/4BRdvBtR3WkFBm99kfuaP

# WebSocket configuration
ORCHESTRATOR_WEBSOCKET_RETRY_COUNT=3
ORCHESTRATOR_WEBSOCKET_RETRY_DELAY=3000

# Optional: Override network (defaults to baseSepolia)
CHAIN_NETWORK=baseSepolia

# Optional: Override shared directory path
# SHARED_PATH=/path/to/shared