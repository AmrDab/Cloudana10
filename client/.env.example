# API base URL (without trailing slash)
# Development default: http://localhost:7002/v1
# Production: set to your deployed API endpoint, e.g. https://api.example.com/v1
VITE_API_URL=

# Auth token for protected API endpoints (optional; falls back to localStorage "auth_token")
# VITE_AUTH_TOKEN=

# Orchestrator deploy endpoint (defaults to VITE_API_URL + /deploy)
# Override if the orchestrator is hosted separately from the main API
# VITE_ORCHESTRATOR_URL=
