{
  "name": "@cloudana/provider-node-server",
  "version": "1.0.0",
  "description": "Provider node server — executes workloads and reports status (run on each provider)",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "dist",
    "ecosystem.config.cjs",
    "package.json",
    "scripts"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:pm2": "npm run build && pm2 start ecosystem.config.cjs",
    "build": "tsc",
    "validate": "tsx src/validate-setup.ts",
    "check": "bash scripts/check-deployment.sh",
    "test-logging": "tsx src/test-logging.ts",
    "test-logging:json": "NODE_ENV=production tsx src/test-logging.ts",
    "test-logging:debug": "LOG_LEVEL=debug tsx src/test-logging.ts",
    "test:help": "bash test-local.sh",
    "test:start": "bash test-local.sh start",
    "test:list": "bash test-local.sh list",
    "test:health": "bash test-local.sh health",
    "test:suite": "bash test-suite.sh",
    "test:suite:basic": "bash test-suite.sh basic"
  },
  "dependencies": {
    "@akashnetwork/akashjs": "^0.10.0",
    "@cosmjs/proto-signing": "^0.34.0",
    "@cosmjs/stargate": "^0.34.0",
    "@hono/node-server": "^1.19.11",
    "@kubernetes/client-node": "^1.4.0",
    "hono": "^4.12.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "pm2": "^5.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  }
}
