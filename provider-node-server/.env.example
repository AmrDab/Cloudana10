# Cloudana Provider Node Configuration

# Server Configuration
PROVIDER_NODE_PORT=4040

# Public Access Configuration
# PUBLIC_HOSTNAME=your-server-ip-or-domain.com
# This is used to generate accessible URLs for deployed workloads
# Examples:
#   PUBLIC_HOSTNAME=195.201.240.253
#   PUBLIC_HOSTNAME=provider.example.com
# If not set, will try to auto-detect or use localhost

# Logging Configuration
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Environment: development | production
# - development: Pretty console logs with colors
# - production: JSON structured logs
NODE_ENV=production

# Kubernetes Configuration (required for K8s workloads)
# KUBECONFIG=/path/to/custom/kubeconfig
# Override default ~/.kube/config location
# 
# Provider node runs in EXTERNAL mode only - never in-cluster.
# Ensure kubectl is configured: kubectl config view

# Advanced Options
# HOSTNAME=provider-node-1
# Custom hostname for logging (defaults to os.hostname())

# ==========================================
# POUW Mining Configuration
# ==========================================
# Enable background POUW mining (earn CLD by contributing compute)
POUW_ENABLED=true
# Your provider wallet address (receives mining rewards)
POUW_PROVIDER_ADDRESS=0xYOUR_WALLET_ADDRESS
# Orchestrator URL (to submit certificates and fetch seeds)
ORCHESTRATOR_URL=http://localhost:7002
# Mining difficulty (leading zero bits required). 8=easy testnet, 16=harder
POUW_DIFFICULTY=12
# Matrix dimension n (n×n matrices). 64=fast CPU, 128=slower, 256=GPU ideal
POUW_MATRIX_SIZE=64
# Attempts per mining tick (tune for CPU usage)
POUW_BATCH_SIZE=100
# How often to refresh the chain seed in ms
POUW_SIGMA_REFRESH_MS=10000
