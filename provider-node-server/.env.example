PROVIDER_NODE_PORT=4040
LOG_LEVEL=info
NODE_ENV=production
PROVIDER_API_KEY=your_api_key_here

# POUW Mining
POUW_ENABLED=true
POUW_PROVIDER_ADDRESS=0xYOUR_WALLET_ADDRESS
ORCHESTRATOR_URL=http://localhost:7002
POUW_DIFFICULTY=12
POUW_MATRIX_SIZE=64
POUW_BATCH_SIZE=100
POUW_SIGMA_REFRESH_MS=10000

# K8s Config
KUBECONFIG=/etc/rancher/k3s/k3s.yaml
