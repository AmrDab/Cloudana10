{
  "name": "cloudana-provider-sdk",
  "version": "1.0.0",
  "description": "Cloudana Provider Node SDK for running decentralized compute workloads",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cloudana-provider": "dist/index.js"
  },
  "scripts": {
    "build": "echo skipped",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build"
