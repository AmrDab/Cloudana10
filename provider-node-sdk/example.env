# Cloudana Provider Node Configuration

# Blockchain Configuration
RPC_URL=https://sepolia.base.org
PROVIDER_PRIVATE_KEY=your_provider_wallet_private_key_here
WORKLOAD_REGISTRY_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
CLD_TOKEN_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# Provider Configuration
MAX_CONCURRENT_JOBS=3
WORK_DIRECTORY=/tmp/cloudana-provider

# IPFS Configuration (Optional - for production use)
PINATA_JWT=your_pinata_jwt_token_here
PINATA_GATEWAY=https://your-pinata-gateway.mypinata.cloud

# Logging Configuration
LOG_LEVEL=info

# Docker Configuration (Advanced)
DOCKER_HOST=unix:///var/run/docker.sock

# Security Settings
ALLOWED_IMAGES=node:18-alpine,python:3.9-slim,nginx:alpine
NETWORK_MODE=bridge
MEMORY_LIMIT=4g
CPU_LIMIT=2