# Cloudana-Akash Bridge Configuration

# =============================================================================
# API SERVER CONFIG
# =============================================================================
PORT=3001
CORS_ORIGIN=http://localhost:7003

# =============================================================================
# ETHEREUM/CLD TOKEN CONFIG
# =============================================================================
# Ethereum RPC endpoint (Base Sepolia for testnet, Base for mainnet)
ETHEREUM_RPC_URL=https://sepolia.base.org

# CLD Token contract address (from Cloudana deployment)
CLD_TOKEN_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# Workload Registry contract address (from Cloudana deployment)  
WORKLOAD_REGISTRY_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# Bridge wallet private key (needs CLD and ETH for gas)
BRIDGE_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef12

# =============================================================================
# AKASH NETWORK CONFIG  
# =============================================================================
# Akash RPC endpoint
AKASH_RPC_ENDPOINT=https://rpc.akash.forbole.com:443

# Akash wallet mnemonic (12 or 24 words)
AKASH_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Akash chain ID (akashnet-2 for mainnet, sandbox for testnet)
AKASH_CHAIN_ID=akashnet-2

# =============================================================================
# ECONOMIC CONFIG
# =============================================================================
# Platform fee in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250

# Exchange rate API for CLD/AKT conversion
EXCHANGE_RATE_API=https://api.coingecko.com/api/v3/simple/price?ids=cloudana,akash-network&vs_currencies=usd

# =============================================================================
# OPTIONAL CONFIG
# =============================================================================
# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Rate limiting (requests per 15 minutes)
RATE_LIMIT_MAX=100

# Maximum job timeout (seconds)
MAX_JOB_TIMEOUT=604800

# Minimum CLD balance for bridge operations
MIN_BRIDGE_BALANCE=1000