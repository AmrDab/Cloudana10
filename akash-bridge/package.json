{
  "name": "cloudana-akash-bridge",
  "version": "1.0.0",
  "description": "Cloudana bridge to Akash Network for hybrid deployment",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/simple-index.js",
    "dev": "ts-node src/simple-index.ts",
