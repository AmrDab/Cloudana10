# Base Sepolia RPC
RPC_URL=https://base-sepolia.drpc.org
# Deployer private key - NEVER commit the real key
PRIVATE_KEY=your_private_key_here
# Comma-separated validator addresses
VALIDATOR_ADDRESSES=0x...
ORCHESTRATOR_ADDRESS=0x...
TREASURY_ADMIN_ADDRESSES=0x...
CHAIN_ID=84532
# BaseScan API key for contract verification
BASE_SEPOLIA_ETHERSCAN_API_KEY=your_etherscan_api_key_here
